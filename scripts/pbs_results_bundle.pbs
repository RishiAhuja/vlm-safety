#!/bin/bash
#PBS -N vlm_results_bundle
#PBS -q cpuq
#PBS -l select=1:ncpus=2:mem=4gb
#PBS -l walltime=01:00:00
#PBS -j oe

set -euo pipefail
cd "$PBS_O_WORKDIR"
export PYTHONUNBUFFERED=1

echo "===== RESULTS BUNDLE ====="
date
echo "PBS_JOBID=${PBS_JOBID:-}"
echo "HOSTNAME=$(hostname)"
python3 scripts/build_results_bundle.py
